#!/usr/bin/env bash
# SingularityMC AppImage entrypoint — Linux bootstrap (Task 11).
#
# 🔴 KRYTYCZNE — ten skrypt jest częścią immutable AppImage bundle.
# Zmiana hash AppImage oznacza że dotychczasowi userzy nie mają
# automatycznego trust — muszą pobrać na nowo. Patrz:
#   docs/superpowers/specs/2026-04-20-universal-installer-auto-update-refactor-design.md §8
#   memory rule: project_installer_hash_stability (Linux analogia mimo braku SmartScreen)
#
# Flow:
#   1. Check czy ~/.local/share/SingularityMC/auto-update istnieje + jest executable
#   2. Jeśli nie — pobierz z GitHub Releases latest (curl lub wget fallback)
#   3. chmod +x + exec
#
# Kolejne uruchomienia: pomija download, od razu exec zainstalowanego
# auto-update. Auto-update sam potem pobiera launcher.tar.gz + jre-linux.tar.gz
# + samoupdates przez self_replace.
#
# URL hardcoded (immutable) per project_release_asset_naming_immutable.

# -o pipefail defense-in-depth. Obecnie AppRun nie ma pipes ale dodanie
# zero kosztowe, chroni przyszłe edycje (per silent-failure-v1 NIT).
set -euo pipefail

AUTO_UPDATE_URL="https://github.com/Echelon-Team/SingularityMC/releases/latest/download/auto-update-linux"
# ${HOME:?} wymusza że HOME jest USTAWIONY i NIEPUSTY. systemd-service
# context może mieć HOME="" (unset + empty string edge case) — bez ? HOME=""
# robi INSTALL_DIR="/.local/share/SingularityMC" (root-owned path), mkdir -p
# failuje z permission denied. ${HOME:?} exit z jasnym message.
INSTALL_DIR="${HOME:?HOME environment variable must be set}/.local/share/SingularityMC"
AUTO_UPDATE_BIN="${INSTALL_DIR}/auto-update"

mkdir -p "$INSTALL_DIR"

# First-run download. Kolejne uruchomienia mają auto-update już z samo-update
# mechanizmu, więc skipujemy network zupełnie.
if [ ! -x "$AUTO_UPDATE_BIN" ]; then
    echo "Pierwsze uruchomienie: pobieranie auto-update z $AUTO_UPDATE_URL"
    # curl preferowany (bsd/most-distro default), wget fallback (Debian-heavy).
    # `command -v ... >/dev/null 2>&1` nie fails pod set -eu bo jest w if-chain.
    if command -v curl >/dev/null 2>&1; then
        if ! curl -fsSL -o "$AUTO_UPDATE_BIN" "$AUTO_UPDATE_URL"; then
            echo "Błąd: nie udało się pobrać auto-update z $AUTO_UPDATE_URL" >&2
            echo "Sprawdź połączenie z internetem i uruchom AppImage ponownie." >&2
            exit 1
        fi
    elif command -v wget >/dev/null 2>&1; then
        if ! wget -qO "$AUTO_UPDATE_BIN" "$AUTO_UPDATE_URL"; then
            echo "Błąd: nie udało się pobrać auto-update z $AUTO_UPDATE_URL" >&2
            echo "Sprawdź połączenie z internetem i uruchom AppImage ponownie." >&2
            exit 1
        fi
    else
        echo "Błąd: brak zarówno curl jak i wget w systemie." >&2
        echo "Zainstaluj jedno z nich (np. 'sudo apt install curl') i spróbuj ponownie." >&2
        exit 1
    fi
    # chmod error context — bez tego set -e exit z cryptic default "chmod:
    # cannot ..." bez wskazówki że to instalacja fail.
    if ! chmod +x "$AUTO_UPDATE_BIN"; then
        echo "Błąd: nie można ustawić uprawnień wykonania na $AUTO_UPDATE_BIN" >&2
        echo "Sprawdź czy dysk nie jest read-only i czy masz dostęp do $INSTALL_DIR" >&2
        exit 1
    fi
    echo "Pobieranie zakończone. Uruchamianie SingularityMC..."
fi

# exec: replaces AppRun process z auto-update. `$AUTO_UPDATE_BIN` wskazuje
# na downloaded path (`~/.local/share/SingularityMC/auto-update`), nie na
# AppImage mount, więc `current_exe().parent()` w Rust (main.rs:80) zwróci
# poprawny install_dir. Nie potrzeba env var propagation — derivacja z
# current_exe jest idempotent między Windows i Linux.
exec "$AUTO_UPDATE_BIN" "$@"
